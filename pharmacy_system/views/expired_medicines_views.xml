<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================
         LIST VIEW — Expired Medicines
         ============================================================ -->
    <record id="view_expired_medicines_list" model="ir.ui.view">
        <field name="name">expired.medicines.list</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <list string="Expired Medicines"
                default_order="lot_expiry_date asc"
                decoration-danger="is_expired == True"
                decoration-warning="is_expired == False and expiring_days &lt;= 90"
                create="0">
                <header>
                    <button name="action_open_expired_report_wizard"
                            string="📄 Print Expired Report"
                            type="object"
                            class="btn-primary"
                            display="always"/>
                </header>
                <field name="barcode" optional="show" />
                <field name="product_id" />
                <field name="lot_id" />
                <field name="x_expiry_month_year" string="Expiry (MM/YYYY)" />
                <field name="expiring_days" string="Days Remaining" optional="show" />
                <field name="boxes_qty" string="Package" />
                <field name="units_qty" string="Remaining Units" />
                <field name="location_id" />
                <field name="is_expired" column_invisible="1" />
                <field name="expiring_days"
                    string="Status"
                    widget="integer"
                    column_invisible="1" />
                <field name="transfer_status" string="Status" readonly="1" />
            </list>
        </field>
    </record>

    <!-- ============================================================
         SEARCH VIEW
         ============================================================ -->
    <record id="view_expired_medicines_search" model="ir.ui.view">
        <field name="name">expired.medicines.search</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_id" />
                <field name="location_id" />
                <field name="lot_id" />

                <!-- Default: truly expired -->
                <filter string="Expired Medicines"
                    name="expired_filter"
                    domain="[
                            ('lot_id','!=',False),
                            ('lot_expiry_date','&lt;',context_today()),
                            ('product_id.x_classification','=','medicine'),
                            ('location_id.usage','!=','expired')
                        ]" />

                <!-- Near-expiry tabs — AFTER today, within window -->
                <filter string="Expiring in 30 Days"
                    name="exp_30"
                    domain="[
                            ('lot_id','!=',False),
                            ('expiring_days','&gt;=',0),
                            ('expiring_days','&lt;=',30),
                            ('quantity','&gt;',0),
                            ('product_id.x_classification','=','medicine'),
                            ('location_id.usage','!=','expired')
                        ]" />
                <filter string="Expiring in 60 Days"
                    name="exp_60"
                    domain="[
                            ('lot_id','!=',False),
                            ('expiring_days','&gt;=',0),
                            ('expiring_days','&lt;=',60),
                            ('quantity','&gt;',0),
                            ('product_id.x_classification','=','medicine'),
                            ('location_id.usage','!=','expired')
                        ]" />
                <filter string="Expiring in 90 Days"
                    name="exp_90"
                    domain="[
                            ('lot_id','!=',False),
                            ('expiring_days','&gt;=',0),
                            ('expiring_days','&lt;=',90),
                            ('quantity','&gt;',0),
                            ('product_id.x_classification','=','medicine'),
                            ('location_id.usage','!=','expired')
                        ]" />
            </search>
        </field>
    </record>

    <!-- ============================================================
         ACTION
         ============================================================ -->
    <record id="action_expired_medicines" model="ir.actions.act_window">
        <field name="name">Expired Medicines</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_expired_medicines_list" />
        <field name="search_view_id" ref="view_expired_medicines_search" />
        <field name="domain">[
            ('quantity','&gt;',0),
            ('lot_id','!=',False),
            ('product_id.x_classification','=','medicine'),
            ('location_id.usage','!=','expired')
            ]</field>
        <field name="context">{'search_default_expired_filter': 1}</field>
    </record>
    <record id="action_open_transfer_wizard_binding" model="ir.actions.server">
        <field name="name">Transfer To Expired Location</field>
        <field name="model_id" ref="stock.model_stock_quant" />
        <field name="binding_model_id" ref="stock.model_stock_quant" />
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
            action = records.action_open_transfer_wizard()
        </field>
    </record>
    <record id="action_open_export_wizard_binding" model="ir.actions.server">
        <field name="name">📥 Export to Excel</field>
        <field name="model_id" ref="stock.model_stock_quant" />
        <field name="binding_model_id" ref="stock.model_stock_quant" />
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.action_open_export_wizard()
        </field>
    </record>
    <!-- ============================================================
         stock.picking list — show x_transfer_tag column
         (inherits existing list view to append column)
         ============================================================ -->
    <record id="view_stock_picking_expired_tag" model="ir.ui.view">
        <field name="name">stock.picking.expired.tag.list</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree" />
        <field name="arch" type="xml">
            <field name="origin" position="after">
                <field name="x_transfer_tag"
                    string="Tag"
                    optional="show"
                    decoration-danger="x_transfer_tag == 'Expired Transfer'" />
            </field>
        </field>
    </record>

    <!-- ============================================================
         MENU
         ============================================================ -->
    <menuitem id="menu_expired_medicines"
        name="Expired Medicines"
        parent="stock.menu_stock_root"
        action="action_expired_medicines"
        sequence="60" />

</odoo>