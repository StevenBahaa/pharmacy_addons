<odoo>
    <record id="view_order_form_inherit_commission" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.commission</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">10000</field>
        <field name="arch" type="xml">
<!-- 
           <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="class">o_sale_order_line_suggestion_compact</attribute>
            </xpath> -->

            <!-- <xpath expr="//field[@name='order_line']//list//field[@name='product_id']" position="attributes">
                <attribute name="widget">sale_product_with_suggestion</attribute>
            </xpath> -->


            <xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="after">
                <field name="commission_amount"
                       readonly="1"
                       optional="hide"
                       column_invisible="parent.enable_product_commission == False"
                       groups="pharmacy_system.group_pharmacy_manager,pharmacy_system.group_pricing_manager"/>
            </xpath>

            <xpath expr="//field[@name='order_line']//form//field[@name='product_id']" position="after">
                <button name="action_open_suggested_products_wizard"
                        type="object"
                        string="Suggested Products"
                        class="btn-secondary"
                        invisible="not product_id"/>
            </xpath>
            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="class">o_sale_order_line_suggestion_compact</attribute>
            </xpath>

           <xpath expr="//field[@name='order_line']//list//field[@name='product_id']" position="before">
                <button
                    name="action_open_suggested_products_wizard"
                    type="object"
                    icon="fa-lightbulb-o"
                    title="Product Suggestions"
                    class="o_product_suggestion_btn"
                    invisible="not product_id"
                    width="1"
                />
            </xpath>

            <!-- LIST: helper fields before product_uom -->
            <xpath expr="//field[@name='order_line']//list//field[@name='product_uom']" position="before">
                <field name="x_package_uom_id" column_invisible="1"/>
                <field name="x_ratio_uom_id" column_invisible="1"/>
                <field name="x_sale_uom_readonly" column_invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='order_line']//list//field[@name='product_uom'][@groups='uom.group_uom']" position="attributes">
                <attribute name="domain">['|', ('id', '=', x_package_uom_id), ('id', '=', x_ratio_uom_id)]</attribute>
                <attribute name="context">{'pharmacy_sale_product_id': product_id, 'pharmacy_sale_product_tmpl_id': product_template_id}</attribute>
                <attribute name="readonly">x_sale_uom_readonly</attribute>
                <attribute name="options">{'no_open': True, 'no_create': True}</attribute>
            </xpath>

            <!-- FORM POPUP -->
            <xpath expr="//field[@name='order_line']//form//field[@name='product_uom']" position="before">
                <field name="x_package_uom_id" invisible="1"/>
                <field name="x_ratio_uom_id" invisible="1"/>
                <field name="x_sale_uom_readonly" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='order_line']//form//field[@name='product_uom'][@groups='uom.group_uom']" position="attributes">
                <attribute name="domain">['|', ('id', '=', x_package_uom_id), ('id', '=', x_ratio_uom_id)]</attribute>
                <attribute name="context">{'pharmacy_sale_product_id': product_id, 'pharmacy_sale_product_tmpl_id': product_template_id}</attribute>
                <attribute name="readonly">x_sale_uom_readonly</attribute>
                <attribute name="options">{'no_open': True, 'no_create': True}</attribute>
            </xpath>

            


        </field>
    </record>
</odoo>