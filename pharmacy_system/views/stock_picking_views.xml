<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id='view_stock_move_line_operation_tree_expiry_month_year' model='ir.ui.view'>
        <field name='name'>stock.move.line.operation.tree.expiry.month.year</field>
        <field name='model'>stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_operation_tree" />
        <field name="arch" type="xml">

            <xpath expr="//field[@name='expiration_date']" position="before">
                <field name="x_product_tracking" column_invisible="1" />
                <field name="x_picking_code" column_invisible="1" />
                <field name="x_use_expiration_date" column_invisible="1" />

                <field name="x_expiry_month_year"
                    placeholder="MM/YYYY"
                    force_save="1"
                    readonly="x_picking_code != 'incoming'"
                    required="x_product_tracking != 'none' and x_picking_code == 'incoming' and x_use_expiration_date"
                />
            </xpath>

            <xpath expr="//field[@name='expiration_date']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='product_uom_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

        </field>

    </record>

    <record id="view_stock_move_line_detailed_operation_tree_expiry_month_year" model="ir.ui.view">
        <field name="name">stock.move.line.detailed.operation.tree.expiry.month.year</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_name']" position="after">
                <field name="x_expiry_month_year" placeholder="MM/YYYY" force_save="1" />
            </xpath>
            <xpath expr="//field[@name='expiration_date']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="stock_picking_form_expired_reason" model="ir.ui.view">
        <field name="name">stock.picking.form.expired.reason</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="inside">
                <group invisible="not is_expired_transfer">
                    <field name="expired_reason" />
                </group>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Expired Logs">
                    <field name="expired_log_ids">
                        <list>
                            <field name="product_id" />
                            <field name="qty" />
                            <field name="source_location_id" />
                            <field name="dest_location_id" />
                            <field name="user_id" />
                            <field name="date" />
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>