<odoo>
    <record id="view_sale_order_form_limit_uom_domain" model="ir.ui.view">
        <field name="name">sale.order.form.limit.uom.domain</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- FORM: add allowed field before visible product_uom -->
            <xpath expr="//field[@name='order_line']//form//field[@name='product_uom'][@groups='uom.group_uom']" position="before">
                <field name="allowed_sale_uom_ids" invisible="1"/>
            </xpath>

            <!-- FORM: restrict visible product_uom -->
            <xpath expr="//field[@name='order_line']//form//field[@name='product_uom'][@groups='uom.group_uom']" position="attributes">
                <attribute name="domain">[('id', 'in', allowed_sale_uom_ids)]</attribute>
                <attribute name="options">{'no_open': True, 'no_create': True}</attribute>
            </xpath>

            <!-- LIST: add allowed field before visible product_uom -->
            <xpath expr="//field[@name='order_line']//list//field[@name='product_uom'][@groups='uom.group_uom']" position="before">
                <field name="allowed_sale_uom_ids" column_invisible="1"/>
            </xpath>

            <!-- LIST: restrict visible product_uom -->
            <xpath expr="//field[@name='order_line']//list//field[@name='product_uom'][@groups='uom.group_uom']" position="attributes">
                <attribute name="domain">[('id', 'in', allowed_sale_uom_ids)]</attribute>
                <attribute name="options">{'no_open': True, 'no_create': True}</attribute>
            </xpath>

        </field>
    </record>
</odoo>