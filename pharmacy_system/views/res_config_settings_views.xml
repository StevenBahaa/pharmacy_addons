<?xml version="1.0" encoding="UTF-8"?>

<odoo>
    <record id="res_config_settings_view_form_inherit_product_commission" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.product.commission</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form" />
        <field name="arch" type="xml">

            <xpath expr="//app[@name='sale_management']" position="inside">
                <block title="Commissions">
                    <setting id='enable_product_commission_setting'
                        string="Enable Product Commission"
                        help="Enable margin-based commission calculation on sales order lines.">
                        <field name="enable_product_commission" />
                    </setting>
                </block>
            </xpath>

        </field>
    </record>

    <record id="res_config_settings_view_form_pharmacy" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pharmacy</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <!-- البحث عن آخر بلوك في إعدادات المخازن والإضافة بعده -->
            <xpath expr="//app[@name='stock']//block[last()]" position="after">
                <block title="Expiry Alerts (Pharmacy)" name="pharmacy_expiry_setting">
                    <setting string="Near Expiry Warning" help="Set days for orange level warnings">
                        <field name="near_expiry_limit" />
                        <span class="ms-2">Days</span>
                    </setting>
                    <setting string="Critical Expiry Alert"
                        help="Set days for red level warnings and POS icon">
                        <field name="critical_expiry_limit" />
                        <span class="ms-2">Days</span>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

    <record id="view_partner_form_inherit_manufacturer" model="ir.ui.view">
        <field name="name">res.partner.form.manufacturer</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="is_manufacturer" string="Manufacturer" />
            </xpath>
        </field>
    </record>
</odoo>