<odoo>
    <record id="view_low_stock_warning_wizard_form" model="ir.ui.view">
        <field name="name">low.stock.warning.wizard.form</field>
        <field name="model">low.stock.warning.wizard</field>
        <field name="arch" type="xml">
            <form string="Low Stock Warning">
                <sheet>
                    <h2 style="color:red;">
                        ⚠️ Low Stock Warning
                    </h2>
                    <field name="line_ids" readonly="1">
                        <list>
                            <field name="product_id"/>
                            <field name="stock"/>
                            <field name="requested_qty"/>
                            <field name="max_qty"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirm_anyway"
                            type="object"
                            string="Confirm Anyway"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>