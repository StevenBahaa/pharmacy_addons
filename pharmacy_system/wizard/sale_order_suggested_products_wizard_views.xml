<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_sale_order_suggested_products_wizard_form" model="ir.ui.view">
        <field name="name">sale.order.suggested.products.wizard.form</field>
        <field name="model">sale.order.suggested.products.wizard</field>
        <field name="arch" type="xml">
            <form string="Suggested Products">
                <sheet>
                    <group>
                        <field name="sale_order_id"/>
                        <field name="sale_order_line_id"/>
                        <field name="product_id"/>
                    </group>

                    <separator string="Suggested Products"/>

                    <field name="suggestion_line_ids" nolabel="1">
                        <list create="0" edit="0" delete="0">
                            <field name="relation_type"/>
                            <field name="related_product_tmpl_id"/>
                            <field name="categ_id"/>
                            <field name="available_qty"/>
                            <field name="sales_price"/>
                            <field name="priority"/>
                            <field name="note"/>
                            <button name="action_add_to_order"
                                    type="object"
                                    string="Add to Order"
                                    class="btn-primary"
                                    invisible="relation_type != 'complementary'"/>
                            <button name="action_replace_current_product"
                                    type="object"
                                    string="Replace"
                                    class="btn-secondary"
                                    invisible="relation_type != 'similar'"/>
                        </list>
                    </field>
                </sheet>

                <footer>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>