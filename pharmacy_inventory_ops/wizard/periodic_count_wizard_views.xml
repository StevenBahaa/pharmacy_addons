<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pharmacy_count_wizard_form" model="ir.ui.view">
        <field name="name">pharmacy.count.wizard.form</field>
        <field name="model">pharmacy.count.wizard</field>
        <field name="arch" type="xml">
            <form string="New Periodic Count">
                <group string="Count Scope">
                    <group>
                        <field name="warehouse_id" required="1"/>
                        <field name="location_id"
                               domain="[('usage','=','internal')]"
                               placeholder="Leave blank for all locations"/>
                        <field name="category_id"
                               placeholder="Leave blank for all categories"/>
                    </group>
                    <group>
                        <field name="count_date" required="1"/>
                        <field name="responsible_id" required="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_create_count"
                            string="Create Periodic Count"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pharmacy_count_wizard" model="ir.actions.act_window">
        <field name="name">New Periodic Count</field>
        <field name="res_model">pharmacy.count.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
