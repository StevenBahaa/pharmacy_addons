<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Multi-company rule: users only see their own company's counts -->
    <record id="pharmacy_count_company_rule" model="ir.rule">
        <field name="name">Pharmacy Count: Multi-company</field>
        <field name="model_id" ref="model_pharmacy_count"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
