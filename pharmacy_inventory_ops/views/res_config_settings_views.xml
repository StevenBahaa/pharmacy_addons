<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Placeholder for future pharmacy-specific settings -->
    <record id="res_config_settings_view_pharmacy_count" model="ir.ui.view">
        <field name="name">res.config.settings.view.pharmacy.count</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='physical_inventory']" position="after">
                <h2>Pharmacy Inventory Count</h2>
                <div class="o_setting_box">
                    <div class="o_setting_left_pane"/>
                    <div class="o_setting_right_pane">
                        <span class="o_form_label">Pharmacy count module is active.</span>
                        <div class="text-muted">
                            Daily spot-checks and periodic full counts with mandatory reason fields.
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
