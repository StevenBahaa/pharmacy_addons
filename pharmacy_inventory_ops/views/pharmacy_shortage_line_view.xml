<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="pharmacy_shortage_line_view_list" model="ir.ui.view">
        <field name="name">pharmacy.shortage.line.view.list</field>
        <field name="model">pharmacy.shortage.line</field>
        <field name="arch" type="xml">
            <list string="Pharmacy Shortage Lines" create="0" edit="0" delete="0">
                <header>
                    <button name="action_refresh_shortage_lines"
                        string="Refresh Shortage List"
                        type="object"
                        class="btn-primary"
                        display="always" />
                </header>
                <field name="product_id" />
                <field name="location_id" />
                <field name="warehouse_id" />
                <field name="onhand_qty" />
                <field name="reserved_qty" />
                <field name="available_qty" />
                <field name="min_qty" />
                <field name="max_qty" />
                <field name="incoming_qty" />
                <field name="shortage_qty" />
            </list>
        </field>
    </record>

    <record id="action_pharmacy_shortage_line" model="ir.actions.act_window">
        <field name="name">Pharmacy Shortage Lines</field>
        <field name="res_model">pharmacy.shortage.line</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="pharmacy_shortage_line_view_list" />
    </record>

    <menuitem id="menu_pharmacy_shortage_root"
        name="Pharmacy Shortage"
        parent="stock.menu_stock_root"
        sequence="80" />

    <menuitem id="menu_pharmacy_shortage_line"
        name="Shortage List"
        parent="menu_pharmacy_shortage_root"
        action="action_pharmacy_shortage_line"
        sequence="10" />
</odoo>