<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_refresh_shortage_lines" model="ir.cron">
        <field name="name">Pharmacy: Refresh Shortage Dashboard</field>
        <field name="model_id" model="ir.model" search="[('model', '=', 'pharmacy.shortage.line')]"/>
        <field name="state">code</field>
        <field name="code">model.action_refresh_shortage_lines()</field>
        <field name="interval_number" eval="1"/>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
