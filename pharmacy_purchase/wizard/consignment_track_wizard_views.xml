<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_consignment_track_wizard_form" model="ir.ui.view">
            <field name="name">pharmacy.consignment.track.wizard.form</field>
            <field name="model">pharmacy.consignment.track.wizard</field>
            <field name="arch" type="xml">
                <form string="Track Stock Consignment">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="purchase_order_id" readonly="1" />
                            </h1>
                        </div>
                        <group string="Stock Tracking Information">
                            <field name="line_ids" nolabel="1">
                                <list create="0" edit="0" delete="0">
                                    <field name="product_id" string="Product" />
                                    <field name="received_qty" string="Received" sum="Total Received" />
                                    <field name="sold_qty" string="Sold" sum="Total Sold" />
                                    <field name="already_paid_qty" string="Already Paid" sum="Total Paid" />
                                    <field name="payable_now_qty" string="Payable Now" sum="Total Payable" />
                                    <field name="payable_remaining_qty" string="Remaining" sum="Total Remaining" />
                                    <field name="status"
                                        widget="badge"
                                        decoration-success="status == 'paid'"
                                        decoration-warning="status == 'partial'"
                                        decoration-info="status == 'pending'" />
                                </list>
                            </field>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_create_payment_bill"
                                type="object"
                                string="PAYMENT — Sold &amp; Unpaid Qty only"
                                class="btn-primary"
                                help="Create vendor bill for sold but unpaid quantities." />
                        <button name="action_create_backorder"
                                type="object"
                                string="BACKORDER"
                                class="btn-secondary"
                                help="Create backorder for unsettled units." />
                        <button string="Cancel" special="cancel" class="btn-secondary" />
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>