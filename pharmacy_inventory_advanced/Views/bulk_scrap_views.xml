<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="view_pharmacy_bulk_scrap_form" model="ir.ui.view">

        <field name="name">pharmacy.bulk.scrap.form</field>

        <field name="model">pharmacy.bulk.scrap</field>

        <field name="arch" type="xml">

            <form string="Bulk Scrap">

                <header>

                    <button
                        name="action_validate"
                        string="Validate All"
                        type="object"
                        class="btn-primary"
                        invisible="state == 'done'"
                    />

                    <field name="state" widget="statusbar"/>

                </header>

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>

                        <field
                            name="date"
                            readonly="state == 'done'"
                        />

                        <field
                            name="user_id"
                            readonly="state == 'done'"
                        />

                    </group>

                    <notebook>

                        <page string="Scrap Lines">

                            <field
                                name="line_ids"
                                readonly="state == 'done'"
                            >

                                <list editable="bottom">

                                    <field name="product_id"/>

                                    <field
                                        name="lot_id"
                                        domain="[('product_id', '=', product_id)]"
                                    />

                                    <field name="quantity"/>

                                    <field name="location_id"/>

                                    <field name="scrap_location_id"/>

                                    <field name="reason"/>

                                </list>

                            </field>

                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>

    </record>

    <!-- LIST VIEW -->
    <record id="view_pharmacy_bulk_scrap_list" model="ir.ui.view">

        <field name="name">pharmacy.bulk.scrap.list</field>

        <field name="model">pharmacy.bulk.scrap</field>

        <field name="arch" type="xml">

            <list>

                <field name="name"/>

                <field name="date"/>

                <field name="user_id"/>

                <field name="state"/>

            </list>

        </field>

    </record>

    <!-- ACTION -->
    <record id="action_pharmacy_bulk_scrap" model="ir.actions.act_window">

        <field name="name">Bulk Scrap</field>

        <field name="res_model">pharmacy.bulk.scrap</field>

        <field name="view_mode">list,form</field>

    </record>

    <!-- MENU -->
    <menuitem
        id="menu_pharmacy_bulk_scrap"
        name="Bulk Scrap"
        parent="stock.menu_stock_warehouse_mgmt"
        action="action_pharmacy_bulk_scrap"
        sequence="10"
    />

</odoo>