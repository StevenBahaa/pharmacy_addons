<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pharmacy_wishlist.WishlistDialog">
        <Dialog title="props.title" size="'md'">
            <div class="wishlist-form p-3">
                <div class="mb-3">
                    <label class="form-label fw-bold">Customer Phone</label>
                    <input type="text" class="form-control" t-model="state.customer_phone" placeholder="Enter phone number..."/>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Product</label>
                    <select class="form-select" t-model="state.product_id">
                        <option value="">Select a product...</option>
                        <t t-foreach="products" t-as="product" t-key="product.id">
                            <option t-att-value="product.id"><t t-esc="product.display_name"/></option>
                        </t>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Quantity</label>
                    <input type="number" class="form-control" t-model="state.quantity" step="1" min="1"/>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Notes</label>
                    <textarea class="form-control" t-model="state.note" rows="3" placeholder="Specific dosage or brand requests..."></textarea>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="onConfirm">Confirm</button>
                <button class="btn btn-secondary" t-on-click="onCancel">Cancel</button>
            </t>
        </Dialog>
    </t>
</templates>
