<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pharmacy_wishlist.WishlistButton">
        <button t-if="isVisible" class="btn btn-secondary btn-lg py-5" t-on-click="onClick">
            <i class="fa fa-star me-1" role="img" aria-label="Wishlist" title="Wishlist" />
            Wishlist
        </button>
    </t>

    <t t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('control-buttons-modal')]" position="inside">
            <WishlistButton />
        </xpath>
    </t>
</templates>
