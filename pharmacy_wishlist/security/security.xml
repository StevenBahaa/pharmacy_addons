<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Groups definition -->
    <record id="group_wishlist_user" model="res.groups">
        <field name="name">Wishlist User</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_wishlist_manager" model="res.groups">
        <field name="name">Wishlist Manager</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('group_wishlist_user'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="pharmacy_wishlist_multi_company_rule" model="ir.rule">
        <field name="name">Pharmacy Wishlist Multi-Company</field>
        <field name="model_id" ref="model_pharmacy_wishlist"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
