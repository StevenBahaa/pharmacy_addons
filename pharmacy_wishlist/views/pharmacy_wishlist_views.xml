<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pharmacy_wishlist_tree" model="ir.ui.view">
        <field name="name">pharmacy.wishlist.tree</field>
        <field name="model">pharmacy.wishlist</field>
        <field name="arch" type="xml">
            <list string="Product Wishlist" decoration-info="state == 'available'" decoration-muted="state == 'called'">
                <field name="create_date" string="Date"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="partner_id"/>
                <field name="customer_phone"/>
                <field name="customer_unique_code"/>
                <field name="shop_name"/>
                <field name="location_names"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge" 
                       decoration-danger="state == 'not_called'" 
                       decoration-success="state == 'available'" 
                       decoration-warning="state == 'no_answer'"
                       decoration-info="state == 'called'"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacy_wishlist_form" model="ir.ui.view">
        <field name="name">pharmacy.wishlist.form</field>
        <field name="model">pharmacy.wishlist</field>
        <field name="arch" type="xml">
            <form string="Product Wishlist">
                <header>
                    <button name="action_set_no_answer" string="No Answer" type="object" class="btn-secondary" invisible="state not in ['not_called', 'available']"/>
                    <button name="action_set_called" string="Mark as Called" type="object" class="btn-primary" invisible="state == 'called'"/>
                    <field name="state" widget="statusbar" statusbar_visible="not_called,available,called"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="partner_id"/>
                            <field name="customer_phone"/>
                        </group>
                        <group>
                            <field name="shop_name"/>
                            <field name="location_names"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="note" placeholder="Customer specific requirements..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_pharmacy_wishlist_search" model="ir.ui.view">
        <field name="name">pharmacy.wishlist.search</field>
        <field name="model">pharmacy.wishlist</field>
        <field name="arch" type="xml">
            <search string="Search Wishlist">
                <field name="product_id"/>
                <field name="partner_id"/>
                <field name="customer_phone"/>
                <filter string="Available Stock" name="available" domain="[('state', '=', 'available')]"/>
                <filter string="Not Called" name="not_called" domain="[('state', '=', 'not_called')]"/>
                <group expand="0" string="Group By">
                    <filter string="Product" name="group_by_product" context="{'group_by': 'product_id'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pharmacy_wishlist" model="ir.actions.act_window">
        <field name="name">Product Wishlist</field>
        <field name="res_model">pharmacy.wishlist</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pharmacy_wishlist_search"/>
        <field name="context">{'search_default_available': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage customer product requests.
            </p>
        </field>
    </record>

    <menuitem id="menu_pharmacy_wishlist_root" 
              name="Product Wishlist" 
              parent="crm.crm_menu_root" 
              action="action_pharmacy_wishlist" 
              sequence="20"/>

    <record id="action_server_wishlist_no_answer" model="ir.actions.server">
        <field name="name">CALL - NOT ANSWERED</field>
        <field name="model_id" ref="pharmacy_wishlist.model_pharmacy_wishlist"/>
        <field name="binding_model_id" ref="pharmacy_wishlist.model_pharmacy_wishlist"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            records.action_set_no_answer()
        </field>
    </record>

    <record id="action_server_wishlist_called" model="ir.actions.server">
        <field name="name">CALLED</field>
        <field name="model_id" ref="pharmacy_wishlist.model_pharmacy_wishlist"/>
        <field name="binding_model_id" ref="pharmacy_wishlist.model_pharmacy_wishlist"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            records.action_set_called()
        </field>
    </record>
</odoo>
