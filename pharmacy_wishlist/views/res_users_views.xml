<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_wishlist_inherit" model="ir.ui.view">
        <field name="name">res.users.form.wishlist.inherit</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='access_rights']/group" position="after">
                <group string="Pharmacy POS Permissions">
                    <field name="wishlist_permission"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
