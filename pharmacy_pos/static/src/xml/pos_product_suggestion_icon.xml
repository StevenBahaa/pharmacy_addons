<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pharmacy_pos.ProductCardSuggestionIcon"
       t-inherit="point_of_sale.ProductCard"
       t-inherit-mode="extension">

        <xpath expr="//article" position="inside">
            <button t-if="props.product.x_has_pos_related_products"
                    class="pharmacy-pos-suggestion-icon"
                    title="Suggested Products"
                    t-on-click="openProductSuggestions">
                <i class="fa fa-lightbulb-o"/>
            </button>
        </xpath>

    </t>

</templates>
