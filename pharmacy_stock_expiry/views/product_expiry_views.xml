<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_expired_card" model="ir.ui.view">
        <field name="name">product.template.expired.card</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="pharmacy_base.view_medicine_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                        type="object"
                        name="action_open_expired_stock"
                        icon="fa-exclamation-triangle">
                    <div class="o_stat_info">
                        <span class="o_stat_value text-danger">
                            <field name="qty_expired"/>
                        </span>
                        <span class="o_stat_text text-danger">
                            Expired Stock
                        </span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <record id="product_product_expired_card" model="ir.ui.view">
        <field name="name">product.product.expired.card</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                        type="object"
                        name="action_open_expired_stock_variant"
                        icon="fa-exclamation-triangle">
                    <div class="o_stat_info">
                        <span class="o_stat_value text-danger">
                            <field name="qty_expired"/>
                        </span>
                        <span class="o_stat_text text-danger">
                            Expired Stock
                        </span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
