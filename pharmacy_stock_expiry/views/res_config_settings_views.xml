<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_pharmacy_expiry" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pharmacy.expiry</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='stock']//block[last()]" position="after">
                <block title="Expiry Alerts (Pharmacy)" name="pharmacy_expiry_setting">
                    <setting string="Near Expiry Warning" help="Set days for orange level warnings">
                        <field name="near_expiry_limit"/>
                        <span class="ms-2">Days</span>
                    </setting>
                    <setting string="Critical Expiry Alert"
                        help="Set days for red level warnings and POS icon">
                        <field name="critical_expiry_limit"/>
                        <span class="ms-2">Days</span>
                    </setting>
                    <setting string="Notification Recipients" help="Inventory Managers who will receive expiry notifications">
                        <field name="notification_recipients" widget="many2many_tags"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
