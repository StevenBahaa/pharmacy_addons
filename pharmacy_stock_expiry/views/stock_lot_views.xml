<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_stock_lot_form_expiry_month_year" model="ir.ui.view">
        <field name="name">stock.lot.form.expiry.month.year</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form" />
        <field name="arch" type="xml">

            <xpath expr="//field[@name='expiration_date']" position="before">
                <field name="x_use_expiration_date" invisible="1" />
                <field name="x_expiry_month_year"
                    placeholder="MM/YYYY"
                    force_save="1"
                    invisible="not x_use_expiration_date"
                />
            </xpath>

            <xpath expr="//field[@name='expiration_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='use_date']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>

            <xpath expr="//field[@name='removal_date']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>

            <xpath expr="//field[@name='alert_date']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>

        </field>
    </record>


    <record id="view_stock_lot_tree_expiry_month_year" model="ir.ui.view">
        <field name="name">stock.lot.list.expiry.month.year</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="x_use_expiration_date" column_invisible="1" />
                <field name="x_expiry_month_year" string="Expiry" invisible="not x_use_expiration_date" />
            </xpath>
            <xpath expr="//field[@name='expiration_date']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_stock_lot_search_expiry_month_year" model="ir.ui.view">
        <field name="name">stock.lot.search.expiry.month.year</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.search_product_lot_filter" />
        <field name="arch" type="xml">

            <xpath expr="//field[@name='product_id']" position="after">
                <field name="x_expiry_month_year"
                    string="Expiry" />
            </xpath>

        </field>
    </record>

    <record id="view_production_lot_tree_inherit_pharmacy" model="ir.ui.view">
        <field name="name">stock.lot.list.inherit.pharmacy</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree" />
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-danger">expiry_state == 'critical'</attribute>
                <attribute name="decoration-warning">expiry_state == 'near'</attribute>
            </xpath>
            <xpath expr="//field[@name='expiration_date']" position="after">
                <field name="expiry_state" column_invisible="True" />
            </xpath>
        </field>
    </record>

    <!-- إضافة الفلاتر في شريط البحث -->
    <record id="view_stock_lot_search_inherit_pharmacy" model="ir.ui.view">
        <field name="name">stock.lot.search.inherit.pharmacy</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.search_product_lot_filter" />
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator />
                <filter string="Critical Expiry (7 Days)" name="critical_expiry"
                    domain="[('expiry_state', '=', 'critical')]" />
                <filter string="Near Expiry (30 Days)" name="near_expiry"
                    domain="[('expiry_state', '=', 'near')]" />
            </xpath>
        </field>
    </record>

</odoo>

