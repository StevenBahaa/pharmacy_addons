<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate="1" عشان لو عدلت التاريخ يدوياً من واجهة أودو ميتغيرش تاني مع كل Upgrade -->
    <data noupdate="1">
        <record id="ir_cron_expiry_alerts" model="ir.cron">
            <!-- اسم المهمة اللي هيظهرلك في قائمة الـ Scheduled Actions -->
            <field name="name">Pharmacy: Check Medication Expiry Daily</field>

            <!-- الموديل اللي فيه الدالة (بما إننا ورثنا stock.lot فبنكتبه هنا) -->
            <field name="model_id" ref="stock.model_stock_lot" />

            <!-- نوع العملية (Code يعني هنشغل كود بايثون) -->
            <field name="state">code</field>

            <!-- ده أهم سطر: استدعاء الدالة اللي برمجناها في ملف sttock_lot.py -->
            <field name="code">model.cron_detect_expired_lots()</field>

            <!--Interval
            Number & Type: يشتغل كل (1) يوم -->
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>

            <!-- خليه نشط أول ما تعمل Upgrade -->
            <field name="active" eval="True" />
        </record>
    </data>
</odoo>