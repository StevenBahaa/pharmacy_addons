        <field name="model_id" ref="model_stock_expired_log"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">['|', ('source_location_id.company_id', '=', False), ('source_location_id.company_id', 'in', company_ids)]</field>
    </record>
</odoo>