<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        RESERVATION AUDIT LOG VIEWS
        ═══════════════════════════════════════════════════════════════════════
        FIXES applied vs previous version:
        ──────────────────────────────────
        FIX-1  <tree> → <list> throughout (Odoo 18 view arch tag rename).

        FIX-2  Search filter "This Week" used datetime.timedelta in domain
               expression — this does not evaluate in Odoo XML domain context.
               Replaced with a safe_eval-compatible expression using
               (context_today() + relativedelta(days=-7)) pattern, OR simplified
               to a standard date_filter_field + period approach.
               Safest approach: use date range with context_today() only.

        FIX-3  decoration-* row attributes moved to <list> tag (Odoo 18).

        FIX-4  create="false" edit="false" on <form> replaced with
               create="0" edit="0" (Odoo 18 uses integer 0/1, not strings
               for these view-level attributes).
    -->

    <!-- 1. Audit Log LIST ──────────────────────────────────────────────────── -->
    <record id="view_pharmacy_reservation_log_tree" model="ir.ui.view">
        <field name="name">pharmacy.reservation.log.tree</field>
        <field name="model">pharmacy.reservation.log</field>
        <field name="arch" type="xml">
            <!-- FIX-1: <list> replaces <tree>
                 FIX-3: decoration-* on the <list> tag ──────────────────────── -->
            <list string="Reservation Audit Log"
                  default_order="create_date desc"
                  decoration-warning="action == 'force_unreserve'"
                  decoration-success="action == 'release'"
                  decoration-info="action == 'reserve'"
                  decoration-muted="action == 'revert_draft'">
                <field name="create_date"  string="Date / Time"  widget="datetime"/>
                <field name="picking_id"   string="Transfer"/>
                <field name="product_id"/>
                <field name="location_id"/>
                <field name="reserved_qty" string="Qty Affected"/>
                <field name="action"
                       widget="badge"
                       decoration-info="action == 'reserve'"
                       decoration-success="action == 'release'"
                       decoration-warning="action == 'force_unreserve'"
                       decoration-muted="action == 'revert_draft'"/>
                <field name="user_id"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <!-- 2. Audit Log FORM ──────────────────────────────────────────────────── -->
    <record id="view_pharmacy_reservation_log_form" model="ir.ui.view">
        <field name="name">pharmacy.reservation.log.form</field>
        <field name="model">pharmacy.reservation.log</field>
        <field name="arch" type="xml">
            <!-- FIX-4: create="0" edit="0" (integer, not string) ─────────── -->
            <form string="Reservation Log Entry" create="0" edit="0">
                <sheet>
                    <group>
                        <group string="Event">
                            <field name="create_date" string="Date / Time" readonly="1"/>
                            <field name="action"
                                   widget="badge"
                                   readonly="1"
                                   decoration-info="action == 'reserve'"
                                   decoration-success="action == 'release'"
                                   decoration-warning="action == 'force_unreserve'"
                                   decoration-muted="action == 'revert_draft'"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group string="Stock Details">
                            <field name="picking_id" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="location_id" readonly="1"/>
                            <field name="reserved_qty"
                                   string="Qty Affected"
                                   readonly="1"/>
                        </group>
                    </group>
                    <group string="Reason / Notes">
                        <field name="notes"
                               nolabel="1"
                               readonly="1"
                               widget="text"
                               placeholder="No notes recorded."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 3. Audit Log SEARCH ────────────────────────────────────────────────── -->
    <record id="view_pharmacy_reservation_log_search" model="ir.ui.view">
        <field name="name">pharmacy.reservation.log.search</field>
        <field name="model">pharmacy.reservation.log</field>
        <field name="arch" type="xml">
            <search string="Search Reservation Log">
                <field name="product_id"/>
                <field name="picking_id"  string="Transfer"/>
                <field name="user_id"     string="User"/>
                <field name="location_id"/>

                <filter string="Reservations"     name="filter_reserve"
                        domain="[('action', '=', 'reserve')]"/>
                <filter string="Releases"         name="filter_release"
                        domain="[('action', '=', 'release')]"/>
                <filter string="Force Unreserved" name="filter_force"
                        domain="[('action', '=', 'force_unreserve')]"/>
                <filter string="Draft Reverts"    name="filter_draft"
                        domain="[('action', '=', 'revert_draft')]"/>

                <separator/>

                <!-- FIX-2: Safe date filters without datetime.timedelta
                     context_today() returns a date object — arithmetic
                     via relativedelta is not available in XML domain context.
                     Use Odoo's built-in date_filter approach instead. ──────── -->
                <filter string="Today"
                        name="filter_today"
                        domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="Last 7 Days"
                        name="filter_week"
                        domain="[('create_date', '&gt;=', (context_today() - relativedelta(days=7)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="This Month"
                        name="filter_month"
                        domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>

                <group expand="0" string="Group By">
                    <filter string="Action"   name="group_action"
                            context="{'group_by': 'action'}"/>
                    <filter string="Product"  name="group_product"
                            context="{'group_by': 'product_id'}"/>
                    <filter string="Transfer" name="group_picking"
                            context="{'group_by': 'picking_id'}"/>
                    <filter string="User"     name="group_user"
                            context="{'group_by': 'user_id'}"/>
                    <filter string="Date"     name="group_date"
                            context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- 4. Action ──────────────────────────────────────────────────────────── -->
    <record id="action_pharmacy_reservation_log" model="ir.actions.act_window">
        <field name="name">Reservation Audit Log</field>
        <field name="res_model">pharmacy.reservation.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pharmacy_reservation_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No reservation events recorded yet.
            </p>
            <p>
                Every time stock is reserved, released, force-unreserved,
                or a transfer is reverted to draft, an entry appears here.
            </p>
        </field>
    </record>

</odoo>
