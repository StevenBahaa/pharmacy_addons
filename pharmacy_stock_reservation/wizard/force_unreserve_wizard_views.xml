<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        FORCE UNRESERVE WIZARD VIEW
        ═══════════════════════════════════════════════════════════════════════
        FIXES applied vs previous version:
        ──────────────────────────────────
        FIX-1  attrs="{}" syntax removed (removed in Odoo 18).
               attrs="{'required': [('reason', '=', False)]}" → required="1"
               (reason is always required by the @api.constrains on the model).
        FIX-2  <tree editable="bottom"> → <list editable="bottom">
               Odoo 18 uses <list> as the view arch tag for list/editable views.
    -->
    <record id="view_force_unreserve_wizard_form" model="ir.ui.view">
        <field name="name">pharmacy.force.unreserve.wizard.form</field>
        <field name="model">pharmacy.force.unreserve.wizard</field>
        <field name="arch" type="xml">
            <form string="Force Unreserve Stock">
                <sheet>
                    <div class="alert alert-warning" role="alert">
                        <strong>&#9888; Manager Action</strong> —
                        This bypasses normal reservation rules.
                        All changes are recorded in the Reservation Audit Log.
                        A mandatory reason is required.
                    </div>
                    <group>
                        <field name="picking_id" readonly="1"/>
                    </group>
                    <separator string="Lines to Unreserve"/>
                    <!-- FIX-2: <list editable="bottom"> replaces <tree editable="bottom"> -->
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="product_id" readonly="1" force_save="1"/>
                            <field name="location_id" readonly="1" force_save="1"/>
                            <field name="reserved_qty"
                                   string="Currently Reserved"
                                   readonly="1"
                                   force_save="1"/>
                            <field name="qty_to_unreserve"
                                   string="Qty to Unreserve"/>
                        </list>
                    </field>
                    <separator string="Reason (mandatory — stored in audit log)"/>
                    <group>
                        <!-- FIX-1: required="1" replaces attrs="" syntax -->
                        <field name="reason"
                               nolabel="1"
                               required="1"
                               widget="text"
                               placeholder="Describe why this force-unreserve is necessary (minimum 10 characters)…"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_force_unreserve"
                            type="object"
                            string="Force Unreserve"
                            class="btn-warning"
                            groups="pharmacy_base.group_inventory_manager"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
