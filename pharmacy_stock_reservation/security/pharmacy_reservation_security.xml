<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ─── Security Groups ──────────────────────────────────────────────── -->
    <!-- â”€â”€â”€ Record Rules â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <record id="rule_reservation_log_multi_company" model="ir.rule">
        <field name="name">Reservation Log: Multi-Company</field>
        <field name="model_id" ref="model_pharmacy_reservation_log"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
        <field name="domain_force">['|', ('location_id.company_id', '=', False), ('location_id.company_id', 'in', company_ids)]</field>
    </record>

    <!-- Only managers can write/delete reservation logs (further restricted by ACL) -->
    <!-- This rule enforces that even managers only see logs for their company -->
    </odoo>
