<?xml version="1.0" encoding="UTF-8"?>
<odoo>

     <record id="module_category_pharmacy" model="ir.module.category">
        <field name="name">Pharmacy</field>
        <field name="description">Pharmacy Management Roles</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_pharmacy_user" model="res.groups">
        <field name="name">Pharmacy User</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>


    <record id="group_pricing_manager" model="res.groups">
        <field name="name">Pricing Manager</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('pharmacy_base.group_pharmacy_user'))]"/>
    </record>

    <record id="group_pharmacist" model="res.groups">
        <field name="name">Pharmacist</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('pharmacy_base.group_pharmacy_user')), (4, ref('point_of_sale.group_pos_user'))]"/>
    </record>

    <record id="group_technician" model="res.groups">
        <field name="name">Technician</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('pharmacy_base.group_pharmacy_user')), (4, ref('point_of_sale.group_pos_user'))]"/>
    </record>

    <record id="group_cashier" model="res.groups">
        <field name="name">Cashier</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('pharmacy_base.group_pharmacy_user')), (4, ref('point_of_sale.group_pos_user'))]"/>
    </record>

    <record id="group_inventory_manager" model="res.groups">
        <field name="name">Inventory Manager</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user')), (4, ref('pharmacy_base.group_pharmacy_user'))]"/>
    </record>

    <record id="group_product_config_manager" model="res.groups">
        <field name="name">Product Configuration Manager</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('pharmacy_base.group_pharmacy_user'))]"/>
    </record>

    <record id="group_compliance_manager" model="res.groups">
        <field name="name">Compliance Manager</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('pharmacy_base.group_pharmacy_user'))]"/>
    </record>

    <record id="group_purchase_manager" model="res.groups">
        <field name="name">Purchase Manager</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user')), (4, ref('pharmacy_base.group_pharmacy_user'))]"/>
    </record>

    <record id="group_purchasing_officer" model="res.groups">
        <field name="name">Purchasing Officer</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user')), (4, ref('pharmacy_base.group_pharmacy_user'))]"/>
    </record>

    <record id="group_accounting_manager" model="res.groups">
        <field name="name">Accounting Manager</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_invoice')), (4, ref('pharmacy_base.group_pharmacy_user'))]"/>
    </record>

    <record id="group_pharmacy_manager" model="res.groups">
        <field name="name">Pharmacy Manager</field>
        <field name="category_id" ref="pharmacy_base.module_category_pharmacy"/>
        <field name="implied_ids" eval="[
            (4, ref('pharmacy_base.group_pharmacy_user')),
            (4, ref('pharmacy_base.group_pricing_manager')),
            (4, ref('pharmacy_base.group_pharmacist')),
            (4, ref('pharmacy_base.group_technician')),
            (4, ref('pharmacy_base.group_cashier')),
            (4, ref('pharmacy_base.group_inventory_manager')),
            (4, ref('pharmacy_base.group_product_config_manager')),
            (4, ref('pharmacy_base.group_compliance_manager')),
            (4, ref('pharmacy_base.group_purchase_manager')),
            (4, ref('pharmacy_base.group_purchasing_officer')),
            (4, ref('pharmacy_base.group_accounting_manager')),
            (4, ref('sales_team.group_sale_manager')),
            (4, ref('point_of_sale.group_pos_manager')),
            (4, ref('base.group_system')),
            (4, ref('base.group_erp_manager'))
        ]"/>
    </record>
</odoo>
